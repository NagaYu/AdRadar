# ───────────────────────────────────────────────────────────
# Dependencies
# ───────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/
.npm/

# ───────────────────────────────────────────────────────────
# Build output
# ───────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ───────────────────────────────────────────────────────────
# Secrets / environment
# ───────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ───────────────────────────────────────────────────────────
# Collected data (snapshots are local state, never commit them)
# Ignore the *contents* (not the dir itself) so data/.gitkeep stays tracked.
# ───────────────────────────────────────────────────────────
data/*
!data/.gitkeep

# ───────────────────────────────────────────────────────────
# Playwright artifacts
# ───────────────────────────────────────────────────────────
playwright-report/
test-results/
.playwright/
*.webm
*.zip

# ───────────────────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────────────────
logs/
*.log

# ───────────────────────────────────────────────────────────
# Local diagnostic / scratch scripts
# ───────────────────────────────────────────────────────────
diag.mjs
diag*.png
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────────────────────────────────
# OS / editor cruft
# ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
